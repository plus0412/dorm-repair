<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.dormrepair.mapper.RepairTypeMapper">

    <resultMap id="RepairTypeResultMap" type="com.example.dormrepair.entity.RepairType">
        <id property="id" column="id"/>
        <result property="typeName" column="type_name"/>
        <result property="description" column="description"/>
        <result property="status" column="status"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <!-- 分页查询（支持按名称、状态筛选） -->
    <select id="selectPageFilter" resultMap="RepairTypeResultMap">
        SELECT * FROM repair_type
        <where>
            <if test="name != null and name != ''">
                AND type_name LIKE CONCAT('%', #{name}, '%')
            </if>
            <if test="status != null">
                AND status = #{status}
            </if>
        </where>
        ORDER BY id
    </select>

    <!-- 查询启用状态的类型列表（下拉用） -->
    <select id="selectListEnabled" resultMap="RepairTypeResultMap">
        SELECT * FROM repair_type WHERE status = 1 ORDER BY id
    </select>

    <!-- 根据 ID 查询 -->
    <select id="selectById" resultMap="RepairTypeResultMap">
        SELECT * FROM repair_type WHERE id = #{id}
    </select>

    <!-- 插入 -->
    <insert id="insert" parameterType="com.example.dormrepair.entity.RepairType" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO repair_type (type_name, description, status)
        VALUES (#{typeName}, #{description}, #{status})
    </insert>

    <!-- 根据 ID 更新 -->
    <update id="updateById" parameterType="com.example.dormrepair.entity.RepairType">
        UPDATE repair_type
        <set>
            <if test="typeName != null">type_name = #{typeName},</if>
            <if test="description != null">description = #{description},</if>
            <if test="status != null">status = #{status},</if>
        </set>
        WHERE id = #{id}
    </update>

    <!-- 根据 ID 删除 -->
    <delete id="deleteById">
        DELETE FROM repair_type WHERE id = #{id}
    </delete>

</mapper>
