<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.dormrepair.mapper.DormBuildingMapper">

    <resultMap id="DormBuildingResultMap" type="com.example.dormrepair.entity.DormBuilding">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="description" column="description"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <!-- 分页查询（支持按名称筛选） -->
    <select id="selectPageFilter" resultMap="DormBuildingResultMap">
        SELECT * FROM dorm_building
        <where>
            <if test="name != null and name != ''">
                AND name LIKE CONCAT('%', #{name}, '%')
            </if>
        </where>
        ORDER BY create_time DESC
    </select>

    <!-- 查询所有（下拉列表用） -->
    <select id="selectListAll" resultMap="DormBuildingResultMap">
        SELECT * FROM dorm_building ORDER BY id
    </select>

    <!-- 根据 ID 查询 -->
    <select id="selectById" resultMap="DormBuildingResultMap">
        SELECT * FROM dorm_building WHERE id = #{id}
    </select>

    <!-- 插入 -->
    <insert id="insert" parameterType="com.example.dormrepair.entity.DormBuilding" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO dorm_building (name, description)
        VALUES (#{name}, #{description})
    </insert>

    <!-- 根据 ID 更新 -->
    <update id="updateById" parameterType="com.example.dormrepair.entity.DormBuilding">
        UPDATE dorm_building
        <set>
            <if test="name != null">name = #{name},</if>
            <if test="description != null">description = #{description},</if>
        </set>
        WHERE id = #{id}
    </update>

    <!-- 根据 ID 删除 -->
    <delete id="deleteById">
        DELETE FROM dorm_building WHERE id = #{id}
    </delete>

</mapper>
