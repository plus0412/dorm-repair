<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.dormrepair.mapper.DormRoomMapper">

    <resultMap id="DormRoomResultMap" type="com.example.dormrepair.entity.DormRoom">
        <id property="id" column="id"/>
        <result property="buildingId" column="building_id"/>
        <result property="roomNo" column="room_no"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
        <result property="buildingName" column="building_name"/>
    </resultMap>

    <!-- 分页查询（支持按宿舍楼ID、房间号筛选） -->
    <select id="selectPageFilter" resultMap="DormRoomResultMap">
        SELECT r.*, b.name AS building_name
        FROM dorm_room r
        LEFT JOIN dorm_building b ON r.building_id = b.id
        <where>
            <if test="buildingId != null">
                AND r.building_id = #{buildingId}
            </if>
            <if test="roomNo != null and roomNo != ''">
                AND r.room_no LIKE CONCAT('%', #{roomNo}, '%')
            </if>
        </where>
        ORDER BY r.id
    </select>

    <!-- 按宿舍楼查询房间列表（下拉用） -->
    <select id="selectListByBuildingId" resultMap="DormRoomResultMap">
        SELECT * FROM dorm_room
        <where>
            <if test="buildingId != null">
                building_id = #{buildingId}
            </if>
        </where>
        ORDER BY room_no
    </select>

    <!-- 根据 ID 查询 -->
    <select id="selectById" resultMap="DormRoomResultMap">
        SELECT r.*, b.name AS building_name
        FROM dorm_room r
        LEFT JOIN dorm_building b ON r.building_id = b.id
        WHERE r.id = #{id}
    </select>

    <!-- 插入 -->
    <insert id="insert" parameterType="com.example.dormrepair.entity.DormRoom" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO dorm_room (building_id, room_no)
        VALUES (#{buildingId}, #{roomNo})
    </insert>

    <!-- 根据 ID 更新 -->
    <update id="updateById" parameterType="com.example.dormrepair.entity.DormRoom">
        UPDATE dorm_room
        <set>
            <if test="buildingId != null">building_id = #{buildingId},</if>
            <if test="roomNo != null">room_no = #{roomNo},</if>
        </set>
        WHERE id = #{id}
    </update>

    <!-- 根据 ID 删除 -->
    <delete id="deleteById">
        DELETE FROM dorm_room WHERE id = #{id}
    </delete>

</mapper>
